# ===========================================
# GPC Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ===========================================

# -----------------
# Firebase Client SDK (Public - exposed to browser)
# -----------------
# Get these from Firebase Console > Project Settings > General > Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# -----------------
# Firebase Admin SDK (Server-side only - KEEP SECRET)
# -----------------
# Project ID (same as client)
FIREBASE_PROJECT_ID=your-project-id

# Service account email from Firebase Console > Project Settings > Service accounts
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Path to service account JSON key file
# Download from Firebase Console > Project Settings > Service accounts > Generate new private key
# For local development: absolute path to the JSON file
# For production: use environment variable or secret manager
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# -----------------
# Session Configuration
# -----------------
# Name for the session cookie (can be customized)
SESSION_COOKIE_NAME=_gpc_session_cookie

# -----------------
# Optional: Rate Limiting (if implemented)
# -----------------
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX_REQUESTS=100
