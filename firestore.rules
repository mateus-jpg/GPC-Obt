service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to get operator data
    function getOperator() {
      return get(/databases/$(database)/documents/operators/$(request.auth.uid)).data;
    }
    
    // Check if user is super admin
    function isSuperAdmin() {
      return request.auth != null && getOperator().role == 'admin';
    }

    // ==================== OPERATORS ====================
    // Client reads own operator doc in AuthContext
    match /operators/{operatorId} {
      allow read: if request.auth != null && request.auth.uid == operatorId;
      allow write: if false;
    }

    // ==================== PROJECTS ====================
    // Client fetches projects by ID in AuthContext
    match /projects/{projectId} {
      allow read: if request.auth != null && (
        isSuperAdmin() ||
        projectId in getOperator().projectIds
      );
      allow write: if false;
    }

    // ==================== STRUCTURES ====================
    // Client fetches structures by ID in AuthContext
    match /structures/{structureId} {
      allow read: if request.auth != null && (
        isSuperAdmin() ||
        structureId in getOperator().structureIds ||
        resource.data.projectId in getOperator().projectIds
      );
      allow write: if false;
    }

    // ==================== CATCH-ALL ====================
    // Everything else uses Admin SDK via server actions
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
